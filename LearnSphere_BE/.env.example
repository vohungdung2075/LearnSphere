# LearnSphere Backend — Environment Variables Template
# ─────────────────────────────────────────────────────
# SAO CHÉP file này thành .env và điền giá trị thực vào
# KHÔNG commit file .env lên Git
# ─────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV=production
# Bật khi API đứng sau đúng 1 reverse proxy/CloudFront/ALB
TRUST_PROXY=true

# ── MongoDB Atlas ─────────────────────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=
# Safe delete Course/Lesson dùng transaction; production nên là Atlas/replica set
MONGODB_REQUIRE_TRANSACTIONS=true

# ── JWT Authentication ────────────────────────────────
# Dùng chuỗi ngẫu nhiên mạnh: openssl rand -hex 64
JWT_SECRET=
JWT_EXPIRES_IN=7d
AUTH_COOKIE_MAX_AGE_DAYS=7
# Chỉ điền khi dùng custom domain chung; thường nên để trống
AUTH_COOKIE_DOMAIN=

# ── Frontend URL (CORS & Email links) ────────────────
# Production: CloudFront domain hoặc custom domain; nhiều origin phân tách bằng dấu phẩy
# Ví dụ: https://d1234abcdef.cloudfront.net
FRONTEND_URL=

# ── Email (Nodemailer) ────────────────────────────────
# Dùng Gmail App Password (không phải mật khẩu Google thật)
# Hoặc thay bằng AWS SES SMTP credentials
EMAIL=
EMAIL_PASSWORD=

# ── AWS S3 ────────────────────────────────────────────
# Khi deploy lên EC2 với IAM Role: KHÔNG cần 2 biến ACCESS_KEY bên dưới
# Chỉ cần khai báo REGION và BUCKET_NAME
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=

# ⚠️  CHỈ dùng khi chạy LOCAL (không có IAM Role)
# Trên EC2 production: XÓA 2 dòng này (EC2 tự dùng IAM Role)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── S3 Presigned URL Expiry ───────────────────────────
S3_UPLOAD_URL_EXPIRES_IN=300
S3_DOWNLOAD_URL_EXPIRES_IN=900
# Video >= 25 MB ở frontend dùng multipart; mỗi part mặc định 10 MB
S3_MULTIPART_PART_SIZE_MB=10
S3_MULTIPART_URL_EXPIRES_IN=3600
# Upload chưa gắn vào Course/Lesson/User sau 24 giờ sẽ bị dọn
UPLOAD_SESSION_TTL_HOURS=24
UPLOAD_CLEANUP_INTERVAL_MINUTES=15
UPLOAD_CLEANUP_BATCH_SIZE=20

# Tác vụ dọn file S3 còn pending/failed sẽ được thử lại theo chu kỳ này
S3_CLEANUP_INTERVAL_MINUTES=5
# Dung lượng quy ước để trang System Monitoring tính phần trăm sử dụng
S3_STORAGE_LIMIT_BYTES=

# ── Course trash cleanup ──────────────────────────────
COURSE_CLEANUP_ENABLED=true
COURSE_TRASH_RETENTION_DAYS=30
COURSE_CLEANUP_INTERVAL_MINUTES=360
COURSE_CLEANUP_BATCH_SIZE=20

# ── AI document indexing / OCR ────────────────────────
AI_DOCUMENT_MAX_BYTES=20971520
AI_INDEX_MAX_CHARS=200000
# Một lượt processing cũ hơn thời gian này được xem là bị gián đoạn
AI_INDEX_STALE_MS=600000
# OCR lần lượt từng trang để tránh giữ toàn bộ ảnh PDF trong RAM
AI_PDF_OCR_MAX_PAGES=12
AI_PDF_OCR_IMAGE_WIDTH=1400
AI_PDF_OCR_TIMEOUT_MS=120000
# Với EC2 t3.micro nên giữ bằng 1
AI_PDF_OCR_MAX_CONCURRENT=1
AI_PDF_OCR_MIN_TEXT_CHARS=200

# ── AI provider ───────────────────────────────────────
# bedrock: dùng AWS Bedrock làm chính và Groq làm fallback
# groq: dùng Groq làm chính và Bedrock làm fallback
AI_PROVIDER=bedrock
AI_PROVIDER_TIMEOUT_MS=120000

BEDROCK_REGION=ap-southeast-1
BEDROCK_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0

# Để trống nếu không dùng fallback Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

AI_RATE_LIMIT_REQUESTS=10
AI_RATE_LIMIT_WINDOW_MS=60000
AI_SUMMARY_STALE_MS=300000
AI_CHAT_CONTEXT_MAX_CHARS=7000
AI_SUMMARY_CONTEXT_MAX_CHARS=9000
AI_QUIZ_CONTEXT_MAX_CHARS=8000
